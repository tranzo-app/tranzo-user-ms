# Copy this file to .env and fill in your values. Do not commit .env.
# Production (profile prod) – used by docker-compose and optionally by: docker run --env-file .env ...

SPRING_PROFILES_ACTIVE=prod
SPRING_JWT_SECRET=your-generated-secret-min-32-chars
SPRING_DATASOURCE_URL=jdbc:postgresql://YOUR_RDS_ENDPOINT:5432/YOUR_DATABASE_NAME
SPRING_DATASOURCE_USERNAME=your_rds_username
SPRING_DATASOURCE_PASSWORD=your_rds_password
AWS_S3_MEDIA_BUCKET=your-bucket-name
AWS_REGION=ap-south-1

# Database name: use the name that EXISTS on your RDS instance.
# - RDS default database is usually "postgres" (always exists).
# - If you created a DB with CREATE DATABASE tranzo_db;, use "tranzo_db".
# So either: .../postgres  or  .../tranzo_db
